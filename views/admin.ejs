<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<title>Админка — Управление товарами</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/styles.css?v=1.0.1">
</head>
<body class="admin-page">

  <div id="bg-animated" aria-hidden="true"></div>
<header class="main-header">
<div class="container header-inner">
  <div class="header-top">
    <div class="header-left">
      <a class="logo" href="/"><img src="/albamount.png" alt="ALBAMOUNT" class="logo-img"></a>
      <div class="header-stats">
        <div class="stat-item">
          <span style="opacity: 0.8;">👥</span>
          <strong style="color: #4caf50;"><%= typeof visitorCount !== 'undefined' ? visitorCount : 0 %></strong>
        </div>
        <div class="stat-item">
          <span style="opacity: 0.8;">👤</span>
          <strong style="color: #2196f3;"><%= typeof userCount !== 'undefined' ? userCount : 0 %></strong>
        </div>
      </div>
    <div class="header-actions">
<span class="user-chip">Админ-панель</span>
<form id="logoutForm" method="POST" action="/logout" style="display:inline;margin-left:10px;">
<button type="submit" class="btn outline small">Выход</button>
</form>
</div>
  </div>
</header>

<main style="margin-bottom: 64px;">

<!-- Модерация товаров -->
<section class="section">
<div class="section-header">
<h2>Модерация товаров</h2>
<span class="badge" style="background:#ff9800;color:#fff;padding:4px 12px;border-radius:6px;font-size:0.9rem;">
<% if (pendingProducts && pendingProducts.length) { %>
<%= pendingProducts.length %> на проверке
<% } else { %>
Нет товаров на модерации
<% } %>
</span>
</div>

<% if (pendingProducts && pendingProducts.length) { %>
<div class="product-grid">
<% pendingProducts.forEach(p => { %>
<div class="product-card" style="border:2px solid #ff9800;">
<h3 class="product-title"><%= p.name %></h3>
<% if (p.image_url) { %>
<img src="<%= p.image_url %>" alt="<%= p.name %>">
<% } else { %>
<div class="no-image">Нет изображения</div>
<% } %>

<div class="product-bottom">
<p class="product-desc"><%= p.description || "—" %></p>
<div class="row" style="justify-content:center; gap:8px;">
<span class="muted">Цена:</span>
<strong class="price"><%= p.price %></strong>
</div>

<% if (p.owner) { %>
<% if (typeof p.owner === 'object' && p.owner.username) { %>
<p class="muted" style="text-align:center;font-size:0.9rem;">От: <%= p.owner.username %></p>
<% } else { %>
<p class="muted" style="text-align:center;font-size:0.9rem;">От: пользователь ID <%= p.owner %></p>
<% } %>
<% } else { %>
<p class="muted" style="text-align:center;font-size:0.9rem;color:#f44336;">⚠️ Владелец не указан</p>
<% } %>

<div class="product-actions" style="flex-direction:column;gap:8px;">
<button class="btn small approve-btn" data-id="<%= p.id %>" data-type="product">
✅ Одобрить
</button>
<button class="btn small reject-btn" data-id="<%= p.id %>" data-type="product">
❌ Отклонить
</button>
<% if (p.link) { %>
<a class="btn small outline" href="<%= p.link %>" target="_blank" rel="noopener">Ссылка</a>
<% } %>
<% if (p.video_url) { %>
<button class="btn small outline" data-video="<%= p.video_url %>">Видео</button>
<% } %>
</div>
</div>
</div>
<% }) %>
</div>
<% } else { %>
<p class="empty-state">Нет товаров на модерации</p>
<% } %>
</section>

<!-- Модерация услуг -->
<section class="section">
<div class="section-header">
<h2>Модерация услуг</h2>
<span class="badge" style="background:#ff9800;color:#fff;padding:4px 12px;border-radius:6px;font-size:0.9rem;">
<% if (pendingServices && pendingServices.length) { %>
<%= pendingServices.length %> на проверке
<% } else { %>
Нет услуг на модерации
<% } %>
</span>
</div>

<% if (pendingServices && pendingServices.length) { %>
<div class="product-grid">
<% pendingServices.forEach(s => { %>
<div class="product-card" style="border:2px solid #ff9800;">
<h3 class="product-title"><%= s.name %></h3>
<% if (s.image_url) { %>
<img src="<%= s.image_url %>" alt="<%= s.name %>">
<% } else { %>
<div class="no-image">Нет изображения</div>
<% } %>

<div class="product-bottom">
<p class="product-desc"><%= s.description || "—" %></p>
<div class="row" style="justify-content:center; gap:8px;">
<span class="muted">Цена:</span>
<strong class="price"><%= s.price %></strong>
</div>

<% if (s.owner) { %>
<% if (typeof s.owner === 'object' && s.owner.username) { %>
<p class="muted" style="text-align:center;font-size:0.9rem;">От: <%= s.owner.username %></p>
<% } else { %>
<p class="muted" style="text-align:center;font-size:0.9rem;">От: пользователь ID <%= s.owner %></p>
<% } %>
<% } else { %>
<p class="muted" style="text-align:center;font-size:0.9rem;color:#f44336;">⚠️ Владелец не указан</p>
<% } %>

<div class="product-actions" style="flex-direction:column;gap:8px;">
<button class="btn small approve-btn" data-id="<%= s.id %>" data-type="service">
✅ Одобрить
</button>
<button class="btn small reject-btn" data-id="<%= s.id %>" data-type="service">
❌ Отклонить
</button>
<% if (s.link) { %>
<a class="btn small outline" href="<%= s.link %>" target="_blank" rel="noopener">Ссылка</a>
<% } %>
<% if (s.video_url) { %>
<button class="btn small outline" data-video="<%= s.video_url %>">Видео</button>
<% } %>
</div>
</div>
</div>
<% }) %>
</div>
<% } else { %>
<p class="empty-state">Нет услуг на модерации</p>
<% } %>
</section>

<!-- Модерация баннеров -->
<section class="section">
<div class="section-header">
<h2>Модерация баннеров</h2>
<span class="badge" style="background:#ff9800;color:#fff;padding:4px 12px;border-radius:6px;font-size:0.9rem;">
<% if (pendingBanners && pendingBanners.length) { %>
<%= pendingBanners.length %> на проверке
<% } else { %>
Нет баннеров на модерации
<% } %>
</span>
</div>

<% if (pendingBanners && pendingBanners.length) { %>
<div class="product-grid">
<% pendingBanners.forEach(b => { %>
<div class="product-card" style="border:2px solid #ff9800;">
<h3 class="product-title">Баннер</h3>
<% if (b.image_url) { %>
<img src="<%= b.image_url %>" alt="Баннер" style="max-height: 200px; object-fit: cover;">
<% } else { %>
<div class="no-image">Нет изображения</div>
<% } %>

<div class="product-bottom">
<% if (b.owner) { %>
<% if (typeof b.owner === 'object' && b.owner.username) { %>
<p class="muted" style="text-align:center;font-size:0.9rem;">От: <%= b.owner.username %></p>
<% } else { %>
<p class="muted" style="text-align:center;font-size:0.9rem;">От: пользователь ID <%= b.owner %></p>
<% } %>
<% } else { %>
<p class="muted" style="text-align:center;font-size:0.9rem;color:#f44336;">⚠️ Владелец не указан</p>
<% } %>

<% if (b.link) { %>
<p class="muted" style="text-align:center;font-size:0.85rem;margin-top:5px;">
🔗 <a href="<%= b.link %>" target="_blank" rel="noopener" style="color:#666;"><%= b.link %></a>
</p>
<% } %>

<div class="product-actions" style="flex-direction:column;gap:8px;">
<button class="btn small approve-btn" data-id="<%= b.id %>" data-type="banner">
✅ Одобрить
</button>
<button class="btn small reject-btn" data-id="<%= b.id %>" data-type="banner">
❌ Отклонить
</button>
<% if (b.link) { %>
<a class="btn small outline" href="<%= b.link %>" target="_blank" rel="noopener">Ссылка</a>
<% } %>
</div>
</div>
</div>
<% }) %>
</div>
<% } else { %>
<p class="empty-state">Нет баннеров на модерации</p>
<% } %>
</section>

<!-- Управление ALBA -->
<section class="section">
<div class="section-header">
<h2>Управление ALBA</h2>
</div>
<form id="adminGrantAlbaForm"
      method="POST"
      action="/api/p1/alba/grant-by-login"
      class="form-grid"
      novalidate>

  <input type="hidden" name="_csrf" value="<%= csrfToken || '' %>">

  <input type="text" id="albaUsername" placeholder="Логин пользователя" required>
  <input type="number" id="albaAmount" placeholder="Количество ALBA" required min="1">
  <input type="text" id="albaComment" placeholder="Комментарий" required>

  <!-- КРИТИЧНО -->

  <button type="button" id="albaSubmitBtn" class="btn primary">
    Начислить ALBA
  </button>
</form>
<div id="albaGrantMsg" class="note" style="margin-top:10px;"></div>

<!-- История транзакций ALBA -->
<div class="section-header" style="margin-top: 30px;">
<h2>История транзакций ALBA</h2>
</div>
<button id="loadTransactionsBtn" class="btn small" style="margin-bottom: 15px;">Загрузить историю</button>
<div id="albaTransactionsContainer">
<p class="empty-state">Нажмите кнопку для загрузки истории транзакций</p>
</div>
</section>

<!-- Модерация видео -->
<section class="section">
<div class="section-header">
<h2>Модерация видео</h2>
<span class="badge" style="background:#ff9800;color:#fff;padding:4px 12px;border-radius:6px;font-size:0.9rem;">
<% if (pendingVideos && pendingVideos.length) { %>
<%= pendingVideos.length %> на проверке
<% } else { %>
Нет видео на модерации
<% } %>
</span>
</div>

<% if (pendingVideos && pendingVideos.length) { %>
<div class="product-grid">
<% pendingVideos.forEach(v => { %>
<div class="product-card" style="border:2px solid #ff9800;">
<h3 class="product-title"><%= v.title || 'Без названия' %></h3>

<div class="video-container">
<button class="btn small outline" data-video="<%= v.videoUrl %>">▶️ Видео</button>
</div>

<div class="product-bottom">
<p class="product-desc"><%= v.description || "—" %></p>

<% if (v.genres && v.genres.length > 0) { %>
<div class="video-genres">
<span class="genre-label">Жанры:</span>
<span class="genre-tags"><%= v.genres.join(', ') %></span>
</div>
<% } %>

<div class="row" style="justify-content:center; gap:8px; margin-top: 10px;">
<span class="muted">Рейтинг:</span>
<strong class="price">👍 <%= v.rating_up %> | 👎 <%= v.rating_down %></strong>
</div>

<% if (v.user) { %>
<% if (typeof v.user === 'object' && v.user.username) { %>
<p class="muted" style="text-align:center;font-size:0.9rem;">Автор: <%= v.user.username %> | <%= v.nickname || '—' %></p>
<% } else { %>
<p class="muted" style="text-align:center;font-size:0.9rem;">Автор: пользователь ID <%= v.userId %></p>
<% } %>
<% } else { %>
<p class="muted" style="text-align:center;font-size:0.9rem;color:#f44336;">⚠️ Автор не указан</p>
<% } %>

<div class="product-actions" style="flex-direction:column;gap:8px;">
<button class="btn small approve-btn" data-id="<%= v.id %>" data-type="video">
✅ Одобрить
</button>
<button class="btn small reject-btn" data-id="<%= v.id %>" data-type="video">
❌ Отклонить
</button>
</div>
</div>
</div>
<% }) %>
</div>
<% } else { %>
<p class="empty-state">Нет видео на модерации</p>
<% } %>
</section>

<!-- Каталог видео -->
<section class="section">
<div class="section-header">
<h2>Каталог видео</h2>
<span class="badge" style="background:#666;color:#fff;padding:4px 12px;border-radius:6px;font-size:0.9rem;">
Всего: <%= videos ? videos.length : 0 %>
</span>
</div>

<% if (videos && videos.length) { %>
<div class="product-grid">
<% videos.forEach(v => { %>
<div class="product-card status-<%= v.status || 'pending' %>">
<h3 class="product-title"><%= v.title || 'Без названия' %></h3>

<div class="video-container">
<button class="btn small outline" data-video="<%= v.videoUrl %>">▶️ Видео</button>
</div>

<div class="product-bottom">
<!-- Статус карточки -->
<div style="text-align:center;margin-bottom:10px;">
<% if (v.status === "pending") { %>
<span class="badge" style="background:#ff9800;color:#fff;padding:4px 12px;border-radius:6px;font-size:0.9rem;">
⏳ На модерации
</span>
<% } else if (v.status === "approved") { %>
<span class="badge" style="background:#4caf50;color:#fff;padding:4px 12px;border-radius:6px;font-size:0.9rem;">
✅ Опубликовано
</span>
<% } else if (v.status === "rejected") { %>
<span class="badge" style="background:#f44336;color:#fff;padding:4px 12px;border-radius:6px;font-size:0.9rem;">
❌ Отклонено
</span>
<% } else if (v.status === "blocked") { %>
<span class="badge" style="background:#666;color:#fff;padding:4px 12px;border-radius:6px;font-size:0.9rem;">
🚫 Заблокировано
</span>
<% } else { %>
<span class="badge" style="background:#666;color:#fff;padding:4px 12px;border-radius:6px;font-size:0.9rem;">
⚠️ Без статуса
</span>
<% } %>
</div>

<p class="product-desc"><%= v.description || "—" %></p>

<% if (v.genres && v.genres.length > 0) { %>
<div class="video-genres">
<span class="genre-label">Жанры:</span>
<span class="genre-tags"><%= v.genres.join(', ') %></span>
</div>
<% } %>

<div class="row" style="justify-content:center; gap:8px; margin-top: 10px;">
<span class="muted">Рейтинг:</span>
<strong class="price">👍 <%= v.rating_up %> | 👎 <%= v.rating_down %></strong>
</div>

<!-- Автор -->
<% if (v.user) { %>
<% if (typeof v.user === 'object' && v.user.username) { %>
<p class="muted" style="text-align:center;font-size:0.85rem;margin-top:5px;">
👤 Автор: <%= v.user.username %> | <%= v.nickname || '—' %>
</p>
<% } else { %>
<p class="muted" style="text-align:center;font-size:0.85rem;margin-top:5px;">
👤 Автор: ID <%= v.userId %>
</p>
<% } %>
<% } else { %>
<p class="muted" style="text-align:center;font-size:0.85rem;margin-top:5px;color:#f44336;">
⚠️ Автор не указан
</p>
<% } %>

<div class="product-actions" style="flex-direction:column;gap:6px;margin-top:10px;">
<!-- Блокировка/Разблокировка -->
<button class="btn small toggle-visibility-btn status-<%= v.status %>"
data-id="<%= v.id %>"
data-status="<%= v.status %>"
data-type="video">
<%= v.status === 'approved' ? '🚫 Заблокировать' : '✅ Разблокировать' %>
</button>

<form method="POST" action="/admin/videos/<%= v.id %>/delete" style="display:inline" onsubmit="return confirm('Удалить видео?');">
<input type="hidden" name="_csrf" value="<%= csrfToken || '' %>">
<button type="submit" class="btn small outline" style="width:100%;">🗑️ Удалить</button>
</form>
</div>
</div>
</div>
<% }) %>
</div>
<% } else { %>
<p class="empty-state">Пока нет видео</p>
<% } %>
</section>

<!-- Каталог товаров -->
<section class="section">
<div class="section-header">
<h2>Каталог товаров</h2>
<span class="badge" style="background:#666;color:#fff;padding:4px 12px;border-radius:6px;font-size:0.9rem;">
Всего: <%= products ? products.length : 0 %>
</span>
</div>

<% if (products && products.length) { %>
<div class="product-grid">
<% products.forEach(p => { %>
<div class="product-card status-<%= p.status || 'pending' %>">
<h3 class="product-title"><%= p.name %></h3>
<% if (p.image_url) { %>
<img src="<%= p.image_url %>" alt="<%= p.name %>">
<% } else { %>
<div class="no-image">Нет изображения</div>
<% } %>

<div class="product-bottom">
<!-- Статус карточки -->
<div style="text-align:center;margin-bottom:10px;">
<% if (p.status === "pending") { %>
<span class="badge" style="background:#ff9800;color:#fff;padding:4px 12px;border-radius:6px;font-size:0.9rem;">
⏳ На модерации
</span>
<% } else if (p.status === "approved") { %>
<span class="badge" style="background:#4caf50;color:#fff;padding:4px 12px;border-radius:6px;font-size:0.9rem;">
✅ Опубликовано
</span>
<% } else if (p.status === "rejected") { %>
<span class="badge" style="background:#f44336;color:#fff;padding:4px 12px;border-radius:6px;font-size:0.9rem;">
❌ Заблокировано
</span>
<% } else { %>
<span class="badge" style="background:#666;color:#fff;padding:4px 12px;border-radius:6px;font-size:0.9rem;">
⚠️ Без статуса
</span>
<% } %>
</div>

<p class="product-desc"><%= p.description || "—" %></p>
<div class="row" style="justify-content:center; gap:8px;">
<span class="muted">Цена:</span>
<strong class="price"><%= p.price %></strong>
</div>

<!-- Владелец -->
<% if (p.owner) { %>
<% if (typeof p.owner === 'object' && p.owner.username) { %>
<p class="muted" style="text-align:center;font-size:0.85rem;margin-top:5px;">
👤 Владелец: <%= p.owner.username %>
</p>
<% } else { %>
<p class="muted" style="text-align:center;font-size:0.85rem;margin-top:5px;">
👤 Владелец: ID <%= p.owner %>
</p>
<% } %>
<% } else { %>
<p class="muted" style="text-align:center;font-size:0.85rem;margin-top:5px;color:#f44336;">
⚠️ Владелец не указан (создано админом)
</p>
<% } %>

<!-- Категория -->
<% if (categories && p.category) { %>
<p class="muted" style="text-align:center;font-size:0.85rem;margin-top:5px;">
📁 <%= categories[p.category] || p.category %>
</p>
<% } %>

<div class="product-actions" style="flex-direction:column;gap:6px;margin-top:10px;">
<!-- Блокировка/Разблокировка -->
<button class="btn small toggle-visibility-btn status-<%= p.status %>"
data-id="<%= p.id %>"
data-status="<%= p.status %>">
<%= p.status === 'approved' ? '🚫 Заблокировать' : '✅ Разблокировать' %>
</button>

<a class="btn small outline" href="/admin/products/<%= p.id %>/edit">✏️ Редактировать</a>

<form method="POST" action="/admin/products/<%= p.id %>/delete" style="display:inline" onsubmit="return confirm('Удалить карточку?');">
<input type="hidden" name="_csrf" value="<%= csrfToken || '' %>">
<button type="submit" class="btn small outline" style="width:100%;">🗑️ Удалить</button>
</form>

<% if (p.link) { %>
<a class="btn small outline" href="<%= p.link %>" target="_blank" rel="noopener">🔗 Ссылка</a>
<% } %>
<% if (p.video_url) { %>
<button class="btn small outline" data-video="<%= p.video_url %>">▶️ Видео</button>
<% } %>
</div>

<!-- Рейтинг (только отображение) -->
<div class="product-rating" data-id="<%= p.id %>" style="margin-top:10px;">
<button class="btn icon" type="button" disabled aria-label="Лайк">▲</button>
<span class="result"><%= (p.likes || 0) - (p.dislikes || 0) %></span>
<button class="btn icon" type="button" disabled aria-label="Дизлайк">▼</button>
<span class="votes">(<%= (p.likes || 0) + (p.dislikes || 0) %> голосов)</span>
</div>
</div>
</div>
<% }) %>
</div>
<% } else { %>
<p class="empty-state">Пока нет товаров</p>
<% } %>
</section>

<!-- Каталог услуг -->
<section class="section">
<div class="section-header">
<h2>Каталог услуг</h2>
<span class="badge" style="background:#666;color:#fff;padding:4px 12px;border-radius:6px;font-size:0.9rem;">
Всего: <%= services ? services.length : 0 %>
</span>
</div>

<% if (services && services.length) { %>
<div class="product-grid">
<% services.forEach(s => { %>
<div class="product-card status-<%= s.status || 'pending' %>">
<h3 class="product-title"><%= s.name %></h3>
<% if (s.image_url) { %>
<img src="<%= s.image_url %>" alt="<%= s.name %>">
<% } else { %>
<div class="no-image">Нет изображения</div>
<% } %>

<div class="product-bottom">
<!-- Статус карточки -->
<div style="text-align:center;margin-bottom:10px;">
<% if (s.status === "pending") { %>
<span class="badge" style="background:#ff9800;color:#fff;padding:4px 12px;border-radius:6px;font-size:0.9rem;">
⏳ На модерации
</span>
<% } else if (s.status === "approved") { %>
<span class="badge" style="background:#4caf50;color:#fff;padding:4px 12px;border-radius:6px;font-size:0.9rem;">
✅ Опубликовано
</span>
<% } else if (s.status === "rejected") { %>
<span class="badge" style="background:#f44336;color:#fff;padding:4px 12px;border-radius:6px;font-size:0.9rem;">
❌ Заблокировано
</span>
<% } else { %>
