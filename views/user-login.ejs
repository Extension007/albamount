<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <title>Вход — Пользователь</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css?v=1.0.1">
  <style>
    body {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      background: #2b2b2b;
      padding: 20px;
    }
    .login-container {
      background: #1a1a1a;
      padding: 40px;
      border-radius: 12px;
      box-shadow: 0 4px 20px rgba(0,0,0,0.5);
      width: 100%;
      max-width: 400px;
    }
    h2 {
      text-align: center;
      margin-bottom: 30px;
      color: #fff;
    }
    form {
      display: flex;
      flex-direction: column;
      gap: 15px;
    }
    input {
      padding: 12px;
      font-size: 14px;
      border: 1px solid #444;
      border-radius: 8px;
      background: #2b2b2b;
      color: #fff;
    }
    input:focus {
      outline: none;
      border-color: #ff3333;
    }
    button {
      padding: 12px;
      background: var(--btn-bg);
      color: var(--color-text);
      border: 2px solid transparent;
      border-radius: var(--btn-radius);
      cursor: pointer;
      font-weight: 600;
      box-shadow: var(--btn-shadow);
      transition: box-shadow .2s ease, transform .15s ease, filter .2s ease;
    }
    button:hover {
      box-shadow: var(--btn-shadow-hover);
      transform: translateY(-1px);
      filter: brightness(1.03);
    }
    .error {
      color: #ff3333;
      margin-top: 10px;
      text-align: center;
      font-size: 14px;
    }
    .link {
      text-align: center;
      margin-top: 20px;
    }
    .link a {
      color: #ff3333;
      text-decoration: none;
    }
    .link a:hover {
      text-decoration: underline;
    }
  </style>
</head>
<body>
  <div id="bg-animated" aria-hidden="true"></div>
  <div class="login-container">
    <h2>Вход для пользователей</h2>

    <form id="loginForm" method="POST" action="/user/login">
      <input type="text" name="username" id="username" placeholder="Логин" required>
      <input type="password" name="password" id="password" placeholder="Пароль" required>
      <input type="hidden" name="_csrf" id="_csrf" value="<%= csrfToken %>">
      <button type="submit">Войти</button>
    </form>

    <div id="loginError">
      <% if (error) { %>
        <p class="error"><%= error %></p>
      <% } %>
    </div>

    <div class="link">
      <a href="/">Вернуться на главную</a>
    </div>
  </div>

  <script>
    (function(){
      function showError(msg){
        var container = document.getElementById('loginError');
        container.innerHTML = '<p class="error">' + (msg || 'Ошибка входа') + '</p>';
      }

      document.addEventListener('DOMContentLoaded', function(){
        var form = document.getElementById('loginForm');
        if (!form) return;

        form.addEventListener('submit', async function(e){
          e.preventDefault();

          var username = document.getElementById('username').value;
          var password = document.getElementById('password').value;
          var csrf = document.getElementById('_csrf').value;

          try {
            var res = await fetch(window.location.origin + '/user/login', {
              method: 'POST',
              credentials: 'include', // важное требование
              headers: {
                'Content-Type': 'application/json',
                'X-CSRF-Token': csrf
              },
              body: JSON.stringify({ username: username, password: password })
            });

            // Если сервер делает redirect, браузер автоматически перенаправит
            if (res.redirected) {
              window.location = res.url;
              return;
            }

            var ct = res.headers.get('content-type') || '';
            if (ct.indexOf('application/json') !== -1) {
              var data = await res.json();
              if (data && data.success) {
                window.location = '/cabinet';
              } else {
                showError(data && data.message ? data.message : 'Неверный логин или пароль');
              }
            } else {
              // При HTML ответе — если статус 200, считаем успешным и переходим
              if (res.status === 200) {
                window.location = '/cabinet';
              } else {
                var text = await res.text();
                showError(text || 'Ошибка входа');
              }
            }
          } catch (err) {
            console.error('Login error:', err);
            showError('Сеть недоступна или сервер не отвечает');
          }
        });
      });
    })();
  </script>
</body>
</html>