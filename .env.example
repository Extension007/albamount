# Server
NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000

# PostgreSQL (Neon or local)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Secrets (min 32 chars in production)
SESSION_SECRET=change-me-to-a-long-random-string-at-least-32-chars
JWT_SECRET=change-me-to-another-long-random-string-at-least-32-chars
JWT_EXPIRES_IN=24h

# Email (optional)
EMAIL_VERIFICATION_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=noreply@example.com

# Cloudinary (optional — local uploads used if unset)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Admin bootstrap (npm run admin:create)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-strong-password

# Referrals
REFERRAL_BONUS_ALBA=10

# Vercel (set automatically on deploy)
# VERCEL=1
